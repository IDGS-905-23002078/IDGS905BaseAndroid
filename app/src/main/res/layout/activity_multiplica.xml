<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_vertical"
    tools:context=".multiplica_AxB.MultiplicaActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Multiplicación AxB (Suma Sucesiva)"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/etNumeroA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ingresa el número A (ej. 3)"
        android:inputType="number"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/etNumeroB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Número de veces a sumar B (ej. 5)"
        android:inputType="number"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnCalcular"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calcular Multiplicación"
        android:textSize="16sp"/>

</LinearLayout>